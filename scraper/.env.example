# ─── Database ───────────────────────────────────────────
# Same MongoDB URI as your backend
MONGODB_URI=mongodb://localhost:27017/yourdb

# ─── Target site ────────────────────────────────────────
# Full URL of the notices/news page to monitor
TARGET_URL=https://example.com/notices

# CSS selector that wraps each individual notice item
# Example: ".notice-item" or "ul.notices li" or "div.post"
NOTICE_ITEM_SELECTOR=.notice-item

# CSS selector for the notice title (relative to each item)
NOTICE_TITLE_SELECTOR=h2, h3, .title

# CSS selector for the notice body text (relative to each item)
NOTICE_BODY_SELECTOR=p, .content, .description

# CSS selector for links inside each notice (attachments + detail links)
NOTICE_LINK_SELECTOR=a

# ─── Scraper behaviour ──────────────────────────────────
# How often to check for new notices (cron syntax)
# Default: every 30 minutes
CRON_SCHEDULE=*/30 * * * *

# true  = save as draft, you publish manually via admin
# false = auto-publish immediately after AI rewrite
AUTO_PUBLISH=false

# ─── AI (Anthropic Claude) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Tone/voice hint injected into the rewrite prompt
# e.g. "formal university", "friendly community portal"
SITE_VOICE=professional

# ─── Attachments ────────────────────────────────────────
# "local" → saves to ATTACHMENT_LOCAL_DIR
# "s3"    → uploads to S3 (fill S3 vars below)
ATTACHMENT_STORAGE=local

ATTACHMENT_LOCAL_DIR=./attachments

# S3 (only needed if ATTACHMENT_STORAGE=s3)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=          # optional, for S3-compatible services like R2

# ─── Misc ───────────────────────────────────────────────
NODE_ENV=development
